# Set these in Vercel → Settings → Environment Variables
ASANA_TOKEN=your_asana_personal_access_token
ANTHROPIC_API_KEY=your_anthropic_api_key_for_pdf_parsing

# Vercel Blob (used by Draft Studio and External Project Folders)
BLOB_READ_WRITE_TOKEN=

# External Project Folders
# Supabase Pro is the configured backend. Copy these from
# Supabase → Project Settings → API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# NEXT_PUBLIC_SUPABASE_URL is accepted as a fallback for SUPABASE_URL.

# Shared password gate for External Project Folders (internal use, V1).
EXTERNAL_FOLDER_PASSWORD=1234

# Retention policy (days from project completion).
RETENTION_DAYS=750

# Cron-job endpoint guard. Vercel sends this as Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=

# Optional. When set, the retention cron sends 30/7-day reminder emails to this
# address. Email provider wiring is left abstract — see lib/external-folders/email.js.
RETENTION_REMINDER_EMAIL=

# Project Intake (native filecard engine). All optional in V1 — the submission
# is always logged server-side and the filecard summary is returned to the user.
# As each integration is configured, the submit route fans out to it.
PROJECT_INTAKE_EMAIL_TO=
POWER_AUTOMATE_PROJECT_INTAKE_WEBHOOK=
ASANA_PROJECT_INTAKE_PROJECT_ID=
ASANA_PAT=
